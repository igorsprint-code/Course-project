<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Информация о системе</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 20px;
        }

        .container {
            background: rgba(255, 255, 255, 0.1);
            backdrop-filter: blur(10px);
            border-radius: 20px;
            padding: 40px;
            box-shadow: 0 8px 32px 0 rgba(31, 38, 135, 0.37);
            border: 1px solid rgba(255, 255, 255, 0.18);
            max-width: 600px;
            width: 100%;
        }

        .header {
            text-align: center;
            margin-bottom: 30px;
        }

        .header-icon {
            font-size: 48px;
            margin-bottom: 15px;
        }

        .main-title {
            font-size: 48px;
            color: white;
            font-weight: bold;
            text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.3);
            letter-spacing: 2px;
        }

        .hostname {
            font-size: 24px;
            color: rgba(255, 255, 255, 0.9);
            margin-top: 10px;
            font-weight: 500;
        }

        .info-box {
            background: rgba(255, 255, 255, 0.15);
            border-radius: 15px;
            padding: 25px;
            margin: 20px 0;
            backdrop-filter: blur(5px);
        }

        .info-label {
            color: rgba(255, 255, 255, 0.8);
            font-size: 16px;
            margin-bottom: 10px;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .info-value {
            color: white;
            font-size: 28px;
            font-weight: bold;
            text-shadow: 1px 1px 2px rgba(0, 0, 0, 0.2);
        }

        .footer {
            text-align: center;
            margin-top: 30px;
            padding-top: 20px;
            border-top: 1px solid rgba(255, 255, 255, 0.2);
        }

        .footer-text {
            color: rgba(255, 255, 255, 0.8);
            font-size: 14px;
            line-height: 1.6;
        }

        .author {
            font-size: 28px;
            font-weight: 700;
            margin-bottom: 10px;
            color: white;
            text-shadow: 1px 1px 3px rgba(0, 0, 0, 0.3);
        }

        .project-info {
            font-size: 24px;
            font-weight: 600;
            margin-bottom: 15px;
            color: rgba(255, 255, 255, 0.95);
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <div class="header-icon">🖥️</div>
            <div class="main-title">{{ ansible_host }}</div>
            <div class="hostname">{{ inventory_hostname }}</div>
        </div>

        <div class="info-box">
            <div class="info-label">IP Address:</div>
            <div class="info-value">{{ ansible_host }}</div>
        </div>

        <div class="info-box">
            <div class="info-label">Operating System:</div>
            <div class="info-value">{{ ansible_distribution }} {{ ansible_distribution_version }}</div>
        </div>

        <div class="footer">
            <div class="footer-text author">Дедяхин И.В.</div>
            <div class="footer-text project-info">Курсовой проект</div>
            <div class="footer-text">Managed by Ansible | Deployed on {{ ansible_date_time.date }}</div>
        </div>
    </div>
</body>
</html>